# Chave de 32 bytes em hex que criptografa o cookie de sessao.
# Gere com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=

# Chave de 32 bytes em hex que cifra o token da Vercel guardado no banco.
# Precisa ser DIFERENTE de SESSION_SECRET.
TOKEN_SECRET=

# Contas, tokens cifrados, auditoria e snapshots.
MONGODB_URI=mongodb://localhost:27017/orbit

# Origem esperada nas requisicoes. Em producao, o dominio real (https://...).
# Sem ela, a validacao usa o cabecalho Host.
# APP_ORIGIN=

# 1 quando houver proxy confiavel na frente (ex.: Vercel), para o limite por IP
# usar o IP real em vez de cair num balde unico.
# TRUST_PROXY=

# Fuso do corte diario dos snapshots. Padrao: America/Sao_Paulo
# APP_TIMEZONE=
