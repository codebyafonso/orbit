# Token pessoal da Vercel: https://vercel.com/account/tokens
# Usado apenas ate o login OAuth entrar (Task 5 do plano de implementacao).
VERCEL_TOKEN=

# Opcional: apenas se os projetos pertencem a um time
# VERCEL_TEAM_ID=team_xxxxxxxxxxxxxxxx

# Chave de 32 bytes em hex para criptografar o cookie de sessao.
# Gere com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=

# Perfil e log de auditoria. Sem esta variavel o painel funciona, so nao persiste nada.
MONGODB_URI=mongodb://localhost:27017/orbit
